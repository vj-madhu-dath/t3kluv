---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Neural Interfacing: Direct Brain-Machine Synthesis | T3kluv"
  description="Redefining the boundary between biological cognition and synthetic processing."
  currentPath="/innovations"
>
  <!-- Hero Section -->
  <section class="max-w-screen-2xl mx-auto px-6 mb-16 pt-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-7">
        <div class="flex items-center space-x-4 mb-6">
          <span class="bg-secondary-container text-secondary-fixed px-3 py-1 text-xs font-label uppercase tracking-widest">Project: Omega</span>
          <div class="h-px flex-grow bg-outline-variant/30"></div>
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-headline font-bold tracking-tighter leading-none mb-8">
          Neural <br /> <span class="text-primary-fixed-dim text-glow">Interfacing</span>
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl leading-relaxed">
          Redefining the boundary between biological cognition and synthetic processing. Our proprietary bio-linkage protocols achieve sub-millisecond latency for direct cortical-silicon data transfer.
        </p>
      </div>
      <div class="lg:col-span-5 flex justify-end">
        <div class="w-full aspect-square relative bg-surface-container-low overflow-hidden">
          <img
            alt="Neural Interface"
            class="w-full h-full object-cover mix-blend-screen opacity-80"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBeXRJTiRdd-pwSqPjwoyCeYx_HnoizStED3UpFpyXkZrM8Hq9sbu18zLI2oh3JsTWTZiYD3LkDwKzyd05qihiQHTP-MIotbEwOi0t6ZDcrMa10MZSwFG-qAYi5sSDpKp6EE6r0ifNndFTaiK2cqLW7uNUqkAU6Ywsn_SU_7J-TRxTqK_7Tthu-Alma3ol7sOKiZoVc9YjG2UxWP-AHXoYxivNj8Iggxoz9kb8EoQHY6YKprWJ7e_apv3Fg_mKKcEovWsdFttGn0wOy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent opacity-40"></div>
        </div>
      </div>
    </div>
    <div class="data-strip mt-12"></div>
  </section>

  <!-- Technical Specifications Grid -->
  <section class="max-w-screen-2xl mx-auto px-6 mb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <!-- Specs Card -->
      <div class="md:col-span-2 bg-surface-container-low p-8 border-l border-primary-fixed-dim/30">
        <h3 class="font-headline text-2xl font-bold mb-8 uppercase tracking-tight">Technical Specifications</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-8 gap-x-12">
          <div>
            <p class="font-label text-xs text-primary-fixed-dim uppercase tracking-widest mb-1">Bandwidth</p>
            <p class="font-headline text-3xl font-medium">4.2 TB/s</p>
            <p class="text-on-surface-variant text-sm mt-2">Aggregate synaptic throughput across 12-node cluster.</p>
          </div>
          <div>
            <p class="font-label text-xs text-primary-fixed-dim uppercase tracking-widest mb-1">Latency</p>
            <p class="font-headline text-3xl font-medium">0.85 ms</p>
            <p class="text-on-surface-variant text-sm mt-2">End-to-end signal propagation from motor cortex.</p>
          </div>
          <div>
            <p class="font-label text-xs text-primary-fixed-dim uppercase tracking-widest mb-1">Biocompatibility</p>
            <p class="font-headline text-3xl font-medium">Grade 9</p>
            <p class="text-on-surface-variant text-sm mt-2">Proprietary hydrogel coating prevents tissue rejection.</p>
          </div>
          <div>
            <p class="font-label text-xs text-primary-fixed-dim uppercase tracking-widest mb-1">Architecture</p>
            <p class="font-headline text-3xl font-medium">RISC-N</p>
            <p class="text-on-surface-variant text-sm mt-2">Neural-optimized instruction set for rapid compute.</p>
          </div>
        </div>
      </div>

      <!-- Feature Diagram -->
      <div class="md:col-span-1 lg:col-span-2 bg-surface-container-high relative overflow-hidden group">
        <img
          alt="Neural Mapping"
          class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 transition-transform duration-700"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBBzE3D4md43CqbAwoJZ4jJE3wi_o1Xcpitu7hGdq7-hrb5THB5xsSxziImuTRs9Dk39l0-GcdxdTgsAnvdXX3S7A6fvhewMtkexb7KyCzm5Mx6P-D86hxU0Uxxrjv0Ch8NY38PiGHVJw9ZT9UpSK8gnqPuu2jVq2-Zb-4-h77MGhMuRwgRf0GOU4MkPyB1Jnog3tzYAgtDXRsMc9xc4nH6Ks-JqgwSyku_HZ_KCtQUOlm4VTBsx8p6eyHhVE63Wj2TyBAcVp-XSJs5"
        />
        <div class="relative p-8 h-full flex flex-col justify-end">
          <div class="mb-4">
            <span class="material-symbols-outlined text-primary-fixed-dim text-4xl" style="font-variation-settings: 'FILL' 1;">hub</span>
          </div>
          <h4 class="font-headline text-xl font-bold mb-2 uppercase">Neural-Mesh Synthesis</h4>
          <p class="text-on-surface-variant text-sm max-w-xs">Visualizing the real-time interaction between biological neurons and synthetic interface nodes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="max-w-screen-2xl mx-auto px-6">
    <h2 class="font-headline text-3xl font-bold mb-12 uppercase tracking-tight flex items-center">
      <span class="w-8 h-8 bg-surface-container-highest flex items-center justify-center mr-4 text-primary-fixed-dim">
        <span class="material-symbols-outlined text-sm">timeline</span>
      </span>
      Project Timeline
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-surface-container-low p-6 border-t border-outline-variant/30 relative">
        <span class="font-label text-xs text-on-surface-variant mb-4 block">Q1 2023</span>
        <h5 class="font-headline font-bold text-lg mb-2">Initial Synthesis</h5>
        <p class="text-sm text-on-surface-variant leading-relaxed">Successful lab-grown neuron integration with Gen-1 silicon substrate.</p>
        <div class="absolute -top-[1px] left-0 w-1/4 h-[2px] bg-primary-fixed-dim"></div>
      </div>
      <div class="bg-surface-container-low p-6 border-t border-outline-variant/30">
        <span class="font-label text-xs text-on-surface-variant mb-4 block">Q4 2023</span>
        <h5 class="font-headline font-bold text-lg mb-2">Latency Breach</h5>
        <p class="text-sm text-on-surface-variant leading-relaxed">Achieved sub-1ms signal transfer for the first time in history.</p>
      </div>
      <div class="bg-surface-container-low p-6 border-t border-outline-variant/30">
        <span class="font-label text-xs text-on-surface-variant mb-4 block">Q2 2024</span>
        <h5 class="font-headline font-bold text-lg mb-2">In Vivo Trials</h5>
        <p class="text-sm text-on-surface-variant leading-relaxed">Phase II human-analog trials demonstrating 98% compatibility.</p>
      </div>
      <div class="bg-surface-container-high p-6 border-t border-primary-fixed-dim">
        <span class="font-label text-xs text-primary-fixed-dim mb-4 block">CURRENT</span>
        <h5 class="font-headline font-bold text-lg mb-2">Clinical Launch</h5>
        <p class="text-sm text-on-surface-variant leading-relaxed">Scaling production of the Delta-class neuro-processor.</p>
      </div>
    </div>
  </section>
</BaseLayout>
