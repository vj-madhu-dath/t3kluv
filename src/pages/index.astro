---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const featuredArticles = (await getCollection('articles')).filter(item => item.data.featured);
const featuredNews = (await getCollection('news')).filter(item => item.data.featured);
const featuredResearch = (await getCollection('research')).filter(item => item.data.featured);

---

<BaseLayout
  title="T3kluv | Digital Architectures"
  description="Discover the future of digital architecture and news. Archiving the next era of cybernetic evolution."
  currentPath="/"
>
  <!-- Hero Section -->
  <section class="relative min-h-[400px] flex items-center overflow-hidden px-8">
    <div class="absolute inset-0 z-0">
      <img
        alt="T3kluv Hero Background"
        class="w-full h-full object-cover hover:grayscale-0 transition-all duration-1000 scale-105"
        src="https://scontent.fcok9-1.fna.fbcdn.net/v/t39.30808-6/598016573_25269303466059189_4636719220809475216_n.jpg?_nc_cat=103&ccb=1-7&_nc_sid=2a1932&_nc_ohc=NO9H9w2zjJoQ7kNvwHEg5Dl&_nc_oc=AdqeoTswfJifCDarlUvC_KMQ4fBwH8kG7Xg7DhO1dUczJJL6BxlMKOexzh-ulWff5SQ&_nc_zt=23&_nc_ht=scontent.fcok9-1.fna&_nc_gid=GDIHXwK8JFwn8oDjP4HJCg&_nc_ss=7a32e&oh=00_AfxwLM91PcokoK7MCX4PZeC-REQGwwNFGI-dQkFc11yg2w&oe=69CD3EB7"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/60 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center w-full">
      <div class="lg:col-span-8">
        <div class="inline-flex items-center space-x-3 mb-6 bg-surface-container/50 border border-outline-variant/20 px-4 py-1.5 backdrop-blur-md">
          <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
          <span class="text-xs font-headline font-bold tracking-widest text-primary-fixed-dim uppercase">System Active // v4.0.2</span>
        </div>
        <h1 class="font-headline text-6xl md:text-8xl font-bold tracking-tighter text-white mb-6 leading-[0.9] uppercase text-glow">
          T3kluv
        </h1>
        <p class="font-body text-xl md:text-2xl text-on-surface-variant max-w-2xl mb-10 leading-relaxed">
          Discover the future of <span class="text-primary-fixed-dim font-semibold italic">digital architecture</span> and news. Archiving the next era of cybernetic evolution.
        </p>
        
      </div>
    </div>
  </section>

  <!-- Featured Intelligence Section -->
  <section class="max-w-7xl mx-auto px-8 py-1">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div>
        <div class="data-strip w-24 mb-6"></div>
        <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter text-white">Featured Intelligence</h2>
      </div>
    </div>
    
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      {featuredArticles.length > 0 && (
        <a href={`/articles/${featuredArticles[0].slug}/`} class="md:col-span-8 group relative overflow-hidden bg-surface-container min-h-[450px] cursor-pointer block">
          <img
            alt={featuredArticles[0].data.title}
            class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-110 transition-transform duration-700"
            src={featuredArticles[0].data.heroImage}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-10 w-full">
            <span class="bg-primary-fixed-dim text-on-primary-fixed text-[10px] font-headline font-bold px-3 py-1 uppercase tracking-widest mb-4 inline-block">Article</span>
            <h3 class="font-headline text-3xl font-bold text-white uppercase tracking-tighter mb-2">{featuredArticles[0].data.title}</h3>
            <p class="text-on-surface-variant line-clamp-2">{featuredArticles[0].data.description}</p>
          </div>
        </a>
      )}

      <div class="md:col-span-4 flex flex-col gap-6">
        {featuredResearch.length > 0 && (
          <a href={`/research/${featuredResearch[0].slug}/`} class="group relative overflow-hidden bg-surface-container min-h-[216px] cursor-pointer block">
            <img
              alt={featuredResearch[0].data.title}
              class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-110 transition-transform duration-700"
              src={featuredResearch[0].data.introductionImage}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6 w-full">
              <span class="bg-on-tertiary-fixed text-surface text-[10px] font-headline font-bold px-3 py-1 uppercase tracking-widest mb-2 inline-block">Research</span>
              <h3 class="font-headline text-xl font-bold text-white uppercase tracking-tighter">{featuredResearch[0].data.title}</h3>
            </div>
          </a>
        )}

        {featuredNews.length > 0 && (
          <a href={`/news/${featuredNews[0].slug}/`} class="group relative overflow-hidden bg-surface-container min-h-[216px] cursor-pointer block">
            <img
              alt={featuredNews[0].data.title}
              class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-110 transition-transform duration-700"
              src={featuredNews[0].data.heroImage}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6 w-full">
              <span class="bg-primary-fixed-dim text-on-primary-fixed text-[10px] font-headline font-bold px-3 py-1 uppercase tracking-widest mb-2 inline-block">Innovation</span>
              <h3 class="font-headline text-xl font-bold text-white uppercase tracking-tighter">{featuredNews[0].data.title}</h3>
            </div>
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="max-w-7xl mx-auto px-8 py-32">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div>
        <div class="data-strip w-24 mb-6"></div>
        <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter text-white">Digital Nexus</h2>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a href="/articles" class="group cursor-pointer">
        <div class="text-5xl font-headline font-black text-outline-variant/20 mb-4 group-hover:text-primary-fixed-dim/20 transition-colors uppercase">01</div>
        <h4 class="font-headline text-2xl font-bold text-white uppercase tracking-tighter mb-4">Articles</h4>
        <p class="text-on-surface-variant text-sm leading-relaxed mb-6">In-depth analysis of emerging technologies and digital transformation trends.</p>
        <div class="data-strip w-full opacity-20 group-hover:opacity-100 transition-opacity"></div>
      </a>

      <a href="/news" class="group cursor-pointer">
        <div class="text-5xl font-headline font-black text-outline-variant/20 mb-4 group-hover:text-primary-fixed-dim/20 transition-colors uppercase">02</div>
        <h4 class="font-headline text-2xl font-bold text-white uppercase tracking-tighter mb-4">News</h4>
        <p class="text-on-surface-variant text-sm leading-relaxed mb-6">What, Who, and When of Tech Industry</p>
        <div class="data-strip w-full opacity-20 group-hover:opacity-100 transition-opacity"></div>
      </a>

      <a href="/research" class="group cursor-pointer">
        <div class="text-5xl font-headline font-black text-outline-variant/20 mb-4 group-hover:text-primary-fixed-dim/20 transition-colors uppercase">03</div>
        <h4 class="font-headline text-2xl font-bold text-white uppercase tracking-tighter mb-4">Research</h4>
        <p class="text-on-surface-variant text-sm leading-relaxed mb-6">Latest research wordlwide</p>
        <div class="data-strip w-full opacity-20 group-hover:opacity-100 transition-opacity"></div>
      </a>
    </div>
  </section>
</BaseLayout>
