---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About T3kluv | The Digital Informers"
  description=""
  currentPath="/about"
>
  <!-- Hero Section -->
  <section class="relative min-h-[819px] flex items-center px-8 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        class="w-full h-full object-cover opacity-30 mix-blend-screen"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBQR6uMBpXVTTiTiJK3r9C0-kCPLpOldo9pr09L2DJJtUMA_870fWZ4jw6rd8Ye0wlq9qYx9RZofzyKCvKrCK-laUAZevBTHSfUUQfvrkXpb8W7B6tHONQNmwBisoLjkK9qdAFEeKTWbA9DSAOU-OpPdVXUrqWFsNeNTo0NcAnJyXi2yFdERwM7fYpQZsYtLxepI-ilY35oJrbLfvIoB4Rh0OwCdnzAjMcq0HPXnkNm65NLBMdmmclLdvnsylrjz9aJTW2vjbZ-kqtG"
        alt="Digital visualization"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-surface to-surface"></div>
    </div>
    <div class="relative z-10 max-w-5xl mx-auto text-center md:text-left w-full">
      <p class="font-label text-primary-fixed-dim tracking-[0.4em] uppercase mb-4 text-sm">Initiating Chronical Protocol</p>
      <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tight text-on-surface mb-8 leading-[0.9]">
        Archiving the <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-fixed-dim to-tertiary-fixed">Next Era of Intelligence</span>
      </h1>
      <div class="data-strip w-32 mb-8"></div>
      <p class="font-body text-on-surface-variant text-xl max-w-2xl leading-relaxed">
        
      </p>
    </div>
  </section>

  <!-- Our Vision Section -->
  <section class="py-24 px-8 bg-surface-container-low">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1 relative">
        <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary-fixed-dim/10 blur-[80px] rounded-full"></div>
        <div class="relative glass-panel p-2 border border-outline-variant/20 rounded-lg">
          <img
            class="w-full grayscale hover:grayscale-0 transition-all duration-700 rounded"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDCI-sOWDM6aOqndfVfyaye7IRryLkN48H8hBABxqxFTSVwFlQ1bGKh3TpIhNUaUb1bF81y_hqe1ZbuhpEo9iW5Q-fmOkJFNLR4V876yxOw4ppzakrEu3_RUYqFFYtv1vKc8qx7yxmXRkNETExTMKJGMjZ_ZWvVN0ze0I22uDgRqrTNmv__9tjqIHYYR-g7ueA9L29Z08tGfQtekCVjEoz51YTNrdqLwmwotnmHTqfN8xd8diL0hgn4OK0X9MwjPgX9ZEtzpGrNESTi"
            alt="T3kluv technology"
          />
        </div>
      </div>
      <div class="order-1 lg:order-2 space-y-8">
        <h2 class="font-headline text-4xl font-bold tracking-tight text-primary">Our Vision</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed">
          At T3kluv, 
        </p>
        <div class="text-center grid grid-cols-3 gap-8 pt-4">
          <div class=" border-l-2 border-primary-fixed-dim pl-6">
            <h4 class="font-headline text-3xl font-bold text-primary-fixed-dim">Observe</h4>
          </div>
          <div class="text-center border-l-2 border-primary-fixed-dim ">
            <h4 class="font-headline text-3xl font-bold text-primary-fixed-dim pl-9">Analyze</h4>
          </div>
          <div class=" text-center border-l-2 border-r-2  border-primary-fixed-dim ">
            <h4 class="font-headline text-3xl font-bold text-primary-fixed-dim ">Inform</h4>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Principles Section -->
  <section class="py-24 px-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <h2 class="font-headline text-4xl font-bold tracking-tight mb-4">Core Principles</h2>
        <p class="text-on-surface-variant max-w-xl">The foundational logic that governs every story we tell.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Principle 1: Structural Integrity -->
        <div class="md:col-span-2 bg-surface-container p-8 rounded-lg border border-outline-variant/10 hover:border-primary-fixed-dim/40 transition-all group">
          <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-6" style="font-variation-settings: 'FILL' 1;">architecture</span>
          <h3 class="font-headline text-2xl font-bold mb-4 group-hover:text-primary-fixed-dim transition-colors">A</h3>
          <p class="text-on-surface-variant leading-relaxed">A-def</p>
        </div>

        <!-- Principle 2: Adaptive Flow -->
        <div class="bg-surface-container-high p-8 rounded-lg border border-outline-variant/10 flex flex-col justify-between">
          <div>
            <span class="material-symbols-outlined text-tertiary-fixed-dim text-4xl mb-6">dynamic_form</span>
            <h3 class="font-headline text-2xl font-bold mb-4">B</h3>
          </div>
          <p class="text-on-surface-variant text-sm">B-def</p>
        </div>

        <!-- Principle 3: Radical Clarity -->
        <div class="bg-surface-container-high p-8 rounded-lg border border-outline-variant/10">
          <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-6">visibility</span>
          <h3 class="font-headline text-2xl font-bold mb-4">C</h3>
          <p class="text-on-surface-variant text-sm">C-def</p>
        </div>

        <!-- Principle 4: The Ethical Firewall -->
        <div class="md:col-span-2 bg-surface-container-lowest p-8 rounded-lg border border-primary-fixed-dim/20 relative overflow-hidden group">
          <div class="absolute right-0 bottom-0 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="material-symbols-outlined text-[120px]" style="font-variation-settings: 'FILL' 1;">security</span>
          </div>
          <div class="relative z-10">
            <h3 class="font-headline text-2xl font-bold mb-4">D</h3>
            <p class="text-on-surface-variant max-w-lg leading-relaxed">D-def</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
