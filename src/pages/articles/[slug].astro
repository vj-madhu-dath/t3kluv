---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, author, readTime, publishDate, heroImage, heroImageAlt, contentImage, contentImageAlt, quote, quoteAttribution, tags } = entry.data;
---

<BaseLayout
  title={`${title} | T3kluv`}
  description={description}
  currentPath="/articles"
>
  <!-- Hero Section -->
  <section class="relative w-full h-[500px] md:h-[870px] overflow-hidden flex items-end">
    <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/40 to-transparent z-10"></div>
    <img
      alt={heroImageAlt}
      class="absolute inset-0 w-full h-full object-cover grayscale brightness-75"
      src={heroImage}
    />
    <div class="relative z-20 max-w-7xl mx-auto px-6 pb-16 md:pb-24 w-full">
      <div class="inline-block px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/30 text-primary-fixed-dim font-label text-xs tracking-widest uppercase mb-6">
        Research Archive // {publishDate}
      </div>
      <h1 class="font-headline text-5xl md:text-7xl font-bold text-primary leading-[0.9] tracking-tighter mb-8 max-w-5xl">
        {title}
      </h1>
      <div class="data-strip mb-8 w-1/4"></div>
      <div class="flex flex-wrap items-center gap-6 text-on-surface-variant font-label text-sm uppercase tracking-widest">
        <div class="flex items-center gap-2">
          <span class="w-8 h-[1px] bg-outline-variant"></span>
          <span>By {author}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]">schedule</span>
          <span>{readTime} Min Read</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="max-w-7xl mx-auto px-6 py-20 grid grid-cols-1 lg:grid-cols-12 gap-16">
    <!-- Main Content -->
    <article class="lg:col-span-8 space-y-10 prose prose-invert">
      <div class="space-y-10">
        <Content />
      </div>

      <!-- Content Image -->
      {contentImage && (
        <div class="my-16 relative aspect-video bg-surface-container-low overflow-hidden group">
          <img
            alt={contentImageAlt}
            class="w-full h-full object-cover opacity-60 grayscale group-hover:scale-105 transition-transform duration-700"
            src={contentImage}
          />
          <div class="absolute bottom-4 left-4 font-label text-[10px] uppercase tracking-widest text-primary-fixed-dim bg-surface/80 backdrop-blur-md px-2 py-1">
            Fig 1.2: {contentImageAlt}
          </div>
        </div>
      )}

      {quote && (
        <blockquote class="border-l-4 border-primary-fixed-dim pl-8 py-4 my-12 bg-surface-container-lowest/50 italic">
          <p class="text-2xl font-headline font-medium text-primary leading-snug">
            "{quote}"
          </p>
          <cite class="block mt-4 text-xs font-label uppercase tracking-widest text-on-secondary-container">— {quoteAttribution}</cite>
        </blockquote>
      )}
    </article>

    <!-- Sidebar -->
    <aside class="lg:col-span-4 space-y-8">
      <div class="space-y-4 bg-surface-container p-6 border border-outline-variant/10">
        <h4 class="font-headline text-xs font-bold text-primary-fixed-dim tracking-[0.2em] uppercase">Executive Summary</h4>
        <p class="text-sm text-on-surface-variant leading-relaxed">
          {description}
        </p>
      </div>

      <div class="space-y-4 bg-surface-container p-6 border border-outline-variant/10">
        <h4 class="font-headline text-xs font-bold text-primary-fixed-dim tracking-[0.2em] uppercase">Key Subjects</h4>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 bg-surface-container-low text-[10px] text-on-surface tracking-tighter border border-outline-variant/20 uppercase">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class="space-y-4 bg-surface-container-low p-6 border border-outline-variant/10">
        <h5 class="font-headline text-xs font-bold text-primary-fixed-dim tracking-[0.2em] uppercase mb-4">Related Articles</h5>
        <div class="space-y-4">
          <div class="group cursor-pointer">
            <h6 class="font-headline text-sm font-bold text-on-surface group-hover:text-primary-fixed-dim transition-colors">Post-Human Privacy: The End of the Anonymous City</h6>
          </div>
          <div class="group cursor-pointer pt-4 border-t border-outline-variant/20">
            <h6 class="font-headline text-sm font-bold text-on-surface group-hover:text-primary-fixed-dim transition-colors">Quantum Encryption vs. Swarm Intelligence</h6>
          </div>
        </div>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  :global(.prose) {
    --prose-body: #d0d0d0;
    --prose-headings: #00daf3;
    --prose-code: #c4b9fe;
    --prose-pre-bg: #1a1f2e;
  }

  :global(.prose h2) {
    @apply font-headline text-3xl font-bold text-primary pt-6 mb-4;
  }

  :global(.prose p) {
    @apply text-on-surface-variant leading-relaxed text-lg;
  }

  :global(.prose a) {
    @apply text-primary-fixed-dim hover:text-primary underline;
  }

  :global(.prose strong) {
    @apply font-bold text-on-surface;
  }

  :global(.prose em) {
    @apply italic;
  }

  :global(.prose ul) {
    @apply list-disc list-inside;
  }

  :global(.prose ol) {
    @apply list-decimal list-inside;
  }
</style>
