---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const researchPapers = await getCollection('research');
  return researchPapers.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const {
  title,
  shortTitle,
  description,
  category,
  whitepaperId,
  author,
  authorTitle,
  publishDate,
  readTime,
  abstract,
  introduction,
  introductionImage,
  introductionImageAlt,
  methodology,
  introductionImage: imgUrl,
  references,
} = entry.data;
---

<BaseLayout
  title={`${title} | T3kluv`}
  description={description}
  currentPath="/research"
>
  <!-- Header Section -->
  <section class="max-w-screen-xl mx-auto px-6 py-12 mb-16">
    <div class="flex flex-wrap gap-4 mb-6">
      <span class="font-label text-xs uppercase tracking-[0.2em] text-primary-fixed-dim bg-primary-fixed-dim/10 px-3 py-1">{category}</span>
      <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant border border-outline-variant/30 px-3 py-1">Whitepaper // {whitepaperId}</span>
    </div>
    <h1 class="font-headline text-4xl md:text-6xl font-bold tracking-tighter text-on-surface leading-tight mb-8">
      {title}
    </h1>
    <div class="data-strip w-32 mb-8"></div>
    <div class="flex flex-col md:flex-row md:items-center gap-8 text-on-surface-variant font-label text-sm">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-surface-container-highest rounded flex items-center justify-center border border-outline-variant/20">
          <span class="material-symbols-outlined text-primary-fixed-dim">account_circle</span>
        </div>
        <div>
          <p class="text-on-surface font-medium">{author}</p>
          <p class="text-xs opacity-70">{authorTitle}</p>
        </div>
      </div>
      <div class="flex flex-col">
        <p class="text-on-surface font-medium">Published</p>
        <p class="text-xs opacity-70">{publishDate}</p>
      </div>
      <div class="flex flex-col">
        <p class="text-on-surface font-medium">Reading Time</p>
        <p class="text-xs opacity-70">{readTime} Minutes</p>
      </div>
      <div class="ml-auto flex gap-4">
        <button class="p-2 border border-outline-variant/20 hover:bg-surface-container-high transition-colors"><span class="material-symbols-outlined">download</span></button>
        <button class="p-2 border border-outline-variant/20 hover:bg-surface-container-high transition-colors"><span class="material-symbols-outlined">share</span></button>
      </div>
    </div>
  </section>

  <!-- Main Content Grid -->
  <div class="max-w-screen-xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20">
    <!-- Sidebar Navigation -->
    <aside class="hidden lg:block lg:col-span-3 sticky top-32 h-fit">
      <nav class="space-y-6">
        <p class="font-label text-xs uppercase tracking-widest text-outline mb-4">Contents</p>
        <ul class="space-y-4 border-l border-outline-variant/20">
          <li class="pl-4 border-l-2 border-primary-fixed-dim -ml-[1px]"><a class="text-primary-fixed-dim text-sm font-medium" href="#abstract">01. Abstract</a></li>
          <li class="pl-4 hover:border-l-2 hover:border-outline transition-all -ml-[1px]"><a class="text-on-surface-variant hover:text-on-surface text-sm" href="#introduction">02. Introduction</a></li>
          <li class="pl-4 hover:border-l-2 hover:border-outline transition-all -ml-[1px]"><a class="text-on-surface-variant hover:text-on-surface text-sm" href="#methodology">03. Methodology</a></li>
          <li class="pl-4 hover:border-l-2 hover:border-outline transition-all -ml-[1px]"><a class="text-on-surface-variant hover:text-on-surface text-sm" href="#data">04. Empirical Data</a></li>
          <li class="pl-4 hover:border-l-2 hover:border-outline transition-all -ml-[1px]"><a class="text-on-surface-variant hover:text-on-surface text-sm" href="#references">05. References</a></li>
        </ul>
        <div class="mt-12 p-6 bg-surface-container-low border border-outline-variant/10">
          <p class="font-headline font-bold text-primary-fixed-dim text-lg mb-2">Need Insights?</p>
          <p class="text-xs text-on-surface-variant mb-4">Access our full data repository on quantum decoherence patterns.</p>
          <button class="w-full bg-primary-fixed-dim text-on-primary-fixed font-label text-xs font-bold py-3 uppercase tracking-wider hover:opacity-90 transition-opacity">Request API Access</button>
        </div>
      </nav>
    </aside>

    <!-- Paper Body -->
    <div class="lg:col-span-9 space-y-16">
      <!-- Abstract Section -->
      <section class="relative p-8 md:p-12 bg-surface-container-low/50 border-l-4 border-primary-fixed-dim" id="abstract">
        <h2 class="font-headline text-2xl font-bold mb-6 text-primary-fixed-dim">01. Abstract</h2>
        <p class="text-lg leading-relaxed text-on-surface font-light italic">
          {abstract}
        </p>
      </section>

      <!-- Introduction Section -->
      <section id="introduction">
        <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-4">
          <span class="text-primary-fixed-dim/30">02.</span> Introduction
        </h2>
        <div class="space-y-6 text-on-surface-variant leading-relaxed">
          {introduction.split('\n\n').map((paragraph) => (
            <p key={paragraph}>{paragraph}</p>
          ))}
        </div>
        {introductionImage && (
          <img
            alt={introductionImageAlt}
            class="w-full grayscale hover:grayscale-0 transition-all duration-700 border border-outline-variant/20 my-8"
            src={introductionImage}
          />
        )}
      </section>

      <!-- Methodology Section -->
      <section id="methodology">
        <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-4">
          <span class="text-primary-fixed-dim/30">03.</span> Methodology
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="md:col-span-2 bg-surface-container p-8 border border-outline-variant/10 hover:border-primary-fixed-dim/30 transition-all">
            <span class="material-symbols-outlined text-primary-fixed-dim mb-4" style="font-size: 32px;">biotech</span>
            <h3 class="font-headline text-xl font-bold mb-3">{methodology.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              {methodology.description}
            </p>
          </div>
          <div class="bg-surface-container-high p-8 border border-outline-variant/10">
            <h3 class="font-headline text-xl font-bold mb-3">Array Specs</h3>
            <ul class="space-y-3 font-label text-xs">
              {methodology.specs.map((spec) => (
                <li key={spec.label} class="flex justify-between border-b border-outline-variant/10 pb-2">
                  <span class="text-on-surface-variant">{spec.label}</span>
                  <span class="text-primary-fixed-dim">{spec.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Data Section -->
      <section id="data">
        <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-4">
          <span class="text-primary-fixed-dim/30">04.</span> Empirical Data
        </h2>
        <div class="bg-surface-container-lowest border border-outline-variant/20 p-8">
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10">
            <div>
              <h3 class="font-headline text-lg font-bold">Coherence Decay Analysis</h3>
              <p class="text-xs text-on-surface-variant font-label">Fig. 4.1: T1 Lifetime vs. Temperature (mK)</p>
            </div>
            <div class="flex gap-4 mt-4 md:mt-0">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 bg-primary-fixed-dim"></div>
                <span class="text-[10px] uppercase font-label">Raw Data</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 bg-tertiary-fixed-dim"></div>
                <span class="text-[10px] uppercase font-label">Predicted</span>
              </div>
            </div>
          </div>
          <!-- Simulated Chart -->
          <div class="h-64 flex items-end gap-2 border-b border-l border-outline-variant/30 pb-2 pl-2">
            <div class="flex-1 bg-surface-container-highest group relative h-[20%] hover:bg-primary-fixed-dim transition-colors"></div>
            <div class="flex-1 bg-surface-container-highest group relative h-[35%] hover:bg-primary-fixed-dim transition-colors"></div>
            <div class="flex-1 bg-surface-container-highest group relative h-[45%] hover:bg-primary-fixed-dim transition-colors"></div>
            <div class="flex-1 bg-surface-container-highest group relative h-[65%] hover:bg-primary-fixed-dim transition-colors"></div>
            <div class="flex-1 bg-surface-container-highest group relative h-[85%] hover:bg-primary-fixed-dim transition-colors"></div>
            <div class="flex-1 bg-primary-fixed-dim/50 group relative h-[95%] hover:bg-primary-fixed-dim transition-colors"></div>
            <div class="flex-1 bg-primary-fixed-dim group relative h-[100%]"></div>
          </div>
        </div>
      </section>

      <!-- References Section -->
      <section id="references">
        <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-4">
          <span class="text-primary-fixed-dim/30">05.</span> References
        </h2>
        <div class="space-y-4 text-on-surface-variant text-sm font-label">
          {references.map((ref) => (
            <p key={ref}>{ref}</p>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
