---
---

<footer class="bg-[#181c22] w-full border-t border-[#3a494a]/20 pt-12 pb-8">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-12 px-12 max-w-7xl mx-auto">
    <!-- Brand Section -->
    <div class="space-y-6">
      <div class="text-xl font-bold text-[#00F5FF] font-headline uppercase tracking-tighter">T3kluv</div>
      <p class="text-[#b9caca] font-['Manrope'] text-sm tracking-wide leading-relaxed">
        The authoritative archive for tech enthusiasts.
      </p>
    </div>  

    <!-- Links Section -->
    <div class="grid grid-cols-2 gap-8">
      <!-- Nexus Column -->
      <div class="space-y-4">
        <h5 class="text-white font-headline font-bold text-xs uppercase tracking-[0.2em] mb-4">Nexus</h5>
        <ul class="space-y-3 font-['Manrope'] text-sm tracking-wide">
          <li><a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors" href="/articles">Articles</a></li>
          <li><a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors" href="/news">News</a></li>
          <li><a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors" href="/research">Research</a></li>
        </ul>
      </div>

      <!-- Connect Column -->
      <div class="space-y-4">
        <h5 class="text-white font-headline font-bold text-xs uppercase tracking-[0.2em] mb-4">Connect</h5>
        <ul class="space-y-3 font-['Manrope'] text-sm tracking-wide">
          <li><a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors" href="#">Twitter</a></li>
          <li><a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors" href="#">LinkedIn</a></li>
          <li><a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors" href="#">Newsletter</a></li>
        </ul>
      </div>
    </div>

    <!-- Legal & Info -->
    <div class="flex flex-col justify-between items-start md:items-end">
      <div class="flex space-x-4 mb-8">
        <a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors opacity-80 hover:opacity-100" href="#">Privacy</a>
        <span class="text-outline-variant/30">/</span>
        <a class="text-[#b9caca] hover:text-[#00F5FF] transition-colors opacity-80 hover:opacity-100" href="#">Terms</a>
      </div>
      <div class="text-[#b9caca] font-['Manrope'] text-sm tracking-wide text-right">
        © 2024 T3kluv. Digital Architectures Reserved.
      </div>
    </div>
  </div>
</footer>
