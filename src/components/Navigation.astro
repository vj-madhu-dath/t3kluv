---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const isActive = (path: string) => {
  if (path === '/' && currentPath === '/') return true;
  if (path !== '/' && currentPath.includes(path.replace('.html', ''))) return true;
  return false;
};
---

<nav class="fixed top-0 w-full z-50 bg-[#10141a]/80 backdrop-blur-xl border-b border-[#3a494a]/20 shadow-[0_0_20px_rgba(0,245,255,0.08)]">
  <div class="flex justify-between items-center px-8 py-4 max-w-screen-2xl mx-auto w-full">
    <!-- Logo -->
    <div class="text-2xl font-black tracking-tighter text-[#00F5FF] font-headline uppercase">
      <a href="/">
        <img
          alt="T3kluv Logo"
          class="h-10 w-auto object-contain hover:brightness-125 transition-brightness"
          src="https://scontent.fcok9-1.fna.fbcdn.net/v/t39.30808-6/494147603_9622635521152569_3296031816547592032_n.jpg?_nc_cat=102&ccb=1-7&_nc_sid=1d70fc&_nc_ohc=2-u2G0L0ReQQ7kNvwHiOdTL&_nc_oc=AdoeFm_ksHc6zrPnWRrLufTlF-c_-gCqRvN5VU5pu5028NuzfHgV2u1K9ErdIzNaKMM&_nc_zt=23&_nc_ht=scontent.fcok9-1.fna&_nc_gid=JnceJCqUm7RPMn2hLJabmQ&_nc_ss=7a32e&oh=00_AfwLnMZM3bYHDgmNy6pZaJwHpWnQh3GRIq457qGTBYEZLg&oe=69CD4631"
        />
      </a>
    </div>

    <!-- Desktop Nav Links -->
    <div class="hidden md:flex items-center space-x-8">
      <a
        class={`font-headline tracking-tight font-bold uppercase text-sm transition-colors ${
          isActive('/') ? 'text-[#00F5FF] border-b-2 border-[#00F5FF] pb-1' : 'text-[#b9caca] hover:text-[#00F5FF]'
        }`}
        href="/"
      >
        Home
      </a>
      <a
        class={`font-headline tracking-tight font-bold uppercase text-sm transition-colors ${
          isActive('articles') ? 'text-[#00F5FF] border-b-2 border-[#00F5FF] pb-1' : 'text-[#b9caca] hover:text-[#00F5FF]'
        }`}
        href="/articles"
      >
        Articles
      </a>
      <a
        class={`font-headline tracking-tight font-bold uppercase text-sm transition-colors ${
          isActive('news') ? 'text-[#00F5FF] border-b-2 border-[#00F5FF] pb-1' : 'text-[#b9caca] hover:text-[#00F5FF]'
        }`}
        href="/news"
      >
        news
      </a>
      <a
        class={`font-headline tracking-tight font-bold uppercase text-sm transition-colors ${
          isActive('research') ? 'text-[#00F5FF] border-b-2 border-[#00F5FF] pb-1' : 'text-[#b9caca] hover:text-[#00F5FF]'
        }`}
        href="/research"
      >
        Research
      </a>
      <a
        class={`font-headline tracking-tight font-bold uppercase text-sm transition-colors ${
          isActive('about') ? 'text-[#00F5FF] border-b-2 border-[#00F5FF] pb-1' : 'text-[#b9caca] hover:text-[#00F5FF]'
        }`}
        href="/about"
      >
        About
      </a>
    </div>

    <!-- Right Actions -->
    <div class="flex items-center space-x-6">
      <!-- <button class="text-[#b9caca] hover:text-[#00F5FF] transition-colors scale-95 active:scale-90 transition-transform">
        <span class="material-symbols-outlined">search</span>
      </button>
      <button class="bg-primary-fixed-dim text-on-primary-fixed px-6 py-2 font-headline font-bold uppercase text-xs tracking-widest hover:brightness-110 transition-all shadow-[0_0_15px_rgba(0,218,243,0.3)] scale-95 active:scale-90">
        Subscribe
      </button> -->
    </div>
  </div>
</nav>
